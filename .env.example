# Copy this file to .env and fill in your API keys
# REQUIRED for Phase 1-2
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPTIONAL — set to true during development (no real API calls)
MOCK_MODE=false

# REQUIRED for Phase 3 (image generation)
GOOGLE_API_KEY=your_google_api_key_here

# REQUIRED for Phase 3 (voice synthesis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OPTIONAL — for Whisper subtitle timing and DALL-E images
OPENAI_API_KEY=your_openai_api_key_here

# OPTIONAL — for Luma video generation
LUMA_API_KEY=your_luma_api_key_here
